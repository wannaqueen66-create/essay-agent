# OpenAI / OpenAI-compatible provider
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
# Fallback / single-agent 模式所用模型
OPENAI_MODEL=gpt-4.1-mini

# ---- 多 agent 评分配置 ----
# SCORING_MODE: multi (Researcher+Skeptic+Judge 三 agent, 推荐) 或 single (旧版单 agent)
SCORING_MODE=multi
# Researcher 只做结构化事实抽取，弱模型即可
RESEARCHER_MODEL=gpt-4.1-mini
# Skeptic 负责主动挑假阳性，需强模型
SKEPTIC_MODEL=gpt-5.4
# Judge 负责综合裁决并给最终分数，需强模型
JUDGE_MODEL=gpt-5.4
AGENT_RETRIES=3
AGENT_RETRY_DELAY=3

# ---- 历史论文渐进式重评分 (v1_single -> v2_multi) ----
LEGACY_RESCORE_ENABLED=true
# 每次运行顺带重评分的 legacy 论文数量上限
LEGACY_RESCORE_PER_RUN=30

# Runtime fetch controls
DAYS_BACK=3
MAX_RESULTS_PER_QUERY=100
MIN_RELEVANCE_SCORE=55
FORCE_REFRESH=false
LOW_SCORE_REFRESH_DAYS=3
LOW_SCORE_REFRESH_BELOW=60

# CORE API (可选，需要免费申请：https://core.ac.uk/services/api)
CORE_API_KEY=

# Brevo email push
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp-relay.brevo.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_brevo_smtp_username
EMAIL_PASSWORD=your_brevo_smtp_password
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
# 多个收件人可用英文逗号分隔，例如：
# EMAIL_TO=you@example.com,another@example.com
EMAIL_USE_TLS=true
REPORT_TOP_N=10
EMAIL_TOP_N=5
PENDING_POOL_DAYS=7
EMPTY_REPORT_EMAIL=false
OUTPUT_RETENTION_DAYS=30
