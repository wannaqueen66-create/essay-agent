  sudo -u "$SERVICE_USER" bash -lc "cd '$INSTALL_DIR' && '$VENV_PY' test_email.py"
}

open_env_editor() { require_install; ${EDITOR:-nano} "$ENV_FILE"; }
open_config_editor() { require_install; ${EDITOR:-nano} "$CONFIG_FILE"; }

apply_timer_time() {
  local run_time="$1"
  sed -i "s|OnCalendar=.*|OnCalendar=*-*-* ${run_time}:00|" /etc/systemd/system/essay-agent.timer
  systemctl daemon-reload
  systemctl restart "$TIMER_NAME"
}

edit_core_settings() {
  require_install
  step "核心配置"
  local current_model current_days current_max current_score current_report current_email_top current_pending current_time
  current_model="$(read_env_value OPENAI_MODEL)"
  current_days="$(read_env_value DAYS_BACK)"
  current_max="$(read_env_value MAX_RESULTS_PER_QUERY)"
  current_score="$(read_env_value MIN_RELEVANCE_SCORE)"
  current_report="$(read_env_value REPORT_TOP_N)"
  current_email_top="$(read_env_value EMAIL_TOP_N)"
  current_pending="$(read_env_value PENDING_POOL_DAYS)"
  current_time="$(current_timer_time)"
  current_time="${current_time:-07:00}"

  ask "模型名称" "$current_model" new_model
  ask "抓取最近几天论文（DAYS_BACK）" "$current_days" new_days
  ask "每个 query 每个源最大抓取数（MAX_RESULTS_PER_QUERY）" "$current_max" new_max
  ask "最低相关性阈值（MIN_RELEVANCE_SCORE）" "$current_score" new_score
  ask "Markdown 报告展示前 N 条（REPORT_TOP_N）" "$current_report" new_report
  ask "邮件正文展示前 N 条（EMAIL_TOP_N）" "$current_email_top" new_email_top
  ask "待展示池窗口天数（PENDING_POOL_DAYS）" "$current_pending" new_pending
  ask "每天自动运行时间（如 07:00）" "$current_time" new_time

  write_env_value OPENAI_MODEL "$new_model"
  write_env_value DAYS_BACK "$new_days"
  write_env_value MAX_RESULTS_PER_QUERY "$new_max"
  write_env_value MIN_RELEVANCE_SCORE "$new_score"
  write_env_value REPORT_TOP_N "$new_report"
  write_env_value EMAIL_TOP_N "$new_email_top"
  write_env_value PENDING_POOL_DAYS "$new_pending"
  apply_timer_time "$new_time"
  info "核心配置已更新"
}

edit_email_settings() {
  require_install
  step "邮件配置"
  local enabled host port username password from to tls
  enabled="$(read_env_value EMAIL_ENABLED)"
  host="$(read_env_value EMAIL_SMTP_HOST)"
  port="$(read_env_value EMAIL_SMTP_PORT)"
  username="$(read_env_value EMAIL_USERNAME)"
  from="$(read_env_value EMAIL_FROM)"
  to="$(read_env_value EMAIL_TO)"
  tls="$(read_env_value EMAIL_USE_TLS)"

  if [[ "$enabled" == "true" ]]; then
    if confirm "是否继续启用邮件推送？" "y"; then enabled="true"; else enabled="false"; fi
  else
    if confirm "是否启用邮件推送？" "n"; then enabled="true"; else enabled="false"; fi
  fi

  if [[ "$enabled" == "true" ]]; then
    ask "SMTP 主机" "${host:-smtp-relay.brevo.com}" host
    ask "SMTP 端口" "${port:-587}" port
    ask "SMTP 用户名" "$username" username
    ask_secret "SMTP 密码（留空则保留原值）" password
    ask "发件人邮箱" "$from" from
    ask "收件人邮箱（多个用英文逗号分隔）" "$to" to
    ask "是否启用 TLS（true/false）" "${tls:-true}" tls
    write_env_value EMAIL_ENABLED "$enabled"
    write_env_value EMAIL_SMTP_HOST "$host"
    write_env_value EMAIL_SMTP_PORT "$port"
    write_env_value EMAIL_USERNAME "$username"
    if [[ -n "$password" ]]; then write_env_value EMAIL_PASSWORD "$password"; fi
    write_env_value EMAIL_FROM "$from"
    write_env_value EMAIL_TO "$to"
    write_env_value EMAIL_USE_TLS "$tls"
  else
    write_env_value EMAIL_ENABLED false
  fi
  info "邮件配置已更新"
}

edit_source_settings() {
  require_install
  step "数据源与 CORE 配置"
  local current_core available_sources current_sources selected_sources source existing
  current_core="$(read_env_value CORE_API_KEY)"
  available_sources=(arxiv openalex crossref semantic_scholar europepmc core)
  mapfile -t current_sources < <(read_sources)
  selected_sources=()

  echo "当前启用的数据源："
  if [[ ${#current_sources[@]} -gt 0 ]]; then
    for source in "${current_sources[@]}"; do echo "  - $source"; done
  else
    echo "  （未检测到）"
  fi
  echo ""
  echo "你可以逐个决定是否启用下面的数据源："
  for source in "${available_sources[@]}"; do
    local default_choice="n"
    for existing in "${current_sources[@]:-}"; do
      if [[ "$existing" == "$source" ]]; then default_choice="y"; break; fi
    done
    if confirm "启用数据源 $source ?" "$default_choice"; then
      selected_sources+=("$source")
    fi
  done

  if [[ ${#selected_sources[@]} -gt 0 ]]; then
    write_sources "$(printf '%s\n' "${selected_sources[@]}")"
    info "数据源列表已更新"
  else
    warn "你没有启用任何数据源，已保留原配置不变"
  fi

  echo ""
  if [[ -n "$current_core" ]]; then echo "当前 CORE API Key：已配置"; else echo "当前 CORE API Key：未配置"; fi
  if confirm "是否配置 / 更新 CORE API Key？" "n"; then
    ask_secret "CORE API Key（留空可清空）" new_core
    write_env_value CORE_API_KEY "$new_core"
    info "CORE API Key 已更新"
  fi

  echo ""
  echo "目标期刊目前仍建议直接编辑 config.yaml。"
  if confirm "是否打开 config.yaml 继续编辑目标期刊或高级源配置？" "n"; then
    open_config_editor
  fi
}

rerun_deploy() {
  require_install
  step "重新执行部署脚本（升级 / 重配）"
  bash "$DEPLOY_SCRIPT"
}

uninstall_agent() {
  require_root
  require_install
  echo ""
  echo -e "${YELLOW}你将要卸载 essay-agent：${NC}"
  echo "- 停止并移除 systemd service/timer"
  echo "- 删除 /usr/local/bin/esag"
  echo "- 删除 $INSTALL_DIR"
  echo "- 删除服务用户 $SERVICE_USER（如果存在）"
  echo ""
  read -r -p "确认卸载？请输入 yes 继续: " ans < /dev/tty || true
  if [[ "$ans" != "yes" ]]; then warn "已取消卸载"; return; fi
  systemctl disable --now "$TIMER_NAME" >/dev/null 2>&1 || true
  systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
  rm -f "/etc/systemd/system/essay-agent.service" "/etc/systemd/system/essay-agent.timer"
  systemctl daemon-reload || true
  rm -f /usr/local/bin/esag
  rm -rf "$INSTALL_DIR"
  if id "$SERVICE_USER" >/dev/null 2>&1; then userdel "$SERVICE_USER" >/dev/null 2>&1 || true; fi
  info "essay-agent 已卸载"
  exit 0
}

