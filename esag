top_level_menu() {
  require_root
  while true; do
    show_header
    if is_installed; then
      echo "[总入口菜单]"
      echo "  当前状态：已安装，可直接进入运维控制台"
    else
      echo "[总入口菜单]"
      echo "  当前状态：未安装，请先执行安装"
    fi
    echo ""
    cat <<'EOF'
[1] 安装 / 重装 essay-agent
[2] 进入 esag 运维控制台
[3] 升级 / 重配
[4] 卸载 essay-agent
[0] 退出
EOF
    echo ""
    read -r -p "请选择操作: " choice < /dev/tty || true
    case "$choice" in
      1) run_installer; pause ;;
      2) if is_installed; then operations_console; else warn "尚未安装，请先执行安装"; pause; fi ;;
      3) if is_installed; then rerun_deploy; pause; else warn "尚未安装，请先执行安装"; pause; fi ;;
      4) if is_installed; then uninstall_agent; else warn "尚未安装，无需卸载"; pause; fi ;;
      0) exit 0 ;;
      *) warn "无效选择"; pause ;;
    esac
  done
}

