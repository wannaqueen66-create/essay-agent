#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="/opt/essay-agent"
SERVICE_NAME="essay-agent.service"
TIMER_NAME="essay-agent.timer"
SERVICE_USER="essay-agent"
ENV_FILE="$INSTALL_DIR/.env"
CONFIG_FILE="$INSTALL_DIR/config.yaml"
VENV_PY="$INSTALL_DIR/.venv/bin/python"
DEPLOY_SCRIPT="$INSTALL_DIR/deploy.sh"
OUTPUT_DIR="$INSTALL_DIR/output"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }
step()  { echo -e "\n${CYAN}${BOLD}>>> $*${NC}"; }

require_root() {
  if [[ ${EUID} -ne 0 ]]; then
    error "请使用 root 运行 esag（普通用户请加 sudo）"
  fi
}

is_installed() {
  [[ -d "$INSTALL_DIR" && -f "$ENV_FILE" && -f "$DEPLOY_SCRIPT" ]]
}

ensure_installed() {
  if ! is_installed; then
    warn "当前未安装 essay-agent，请先执行 [1] 安装 / 重装。"
    return 1
  fi
  return 0
}

read_env_value() {
  local key="$1"
  if [[ ! -f "$ENV_FILE" ]]; then
    return 0
  fi
  local line
  line="$(grep -E "^${key}=" "$ENV_FILE" | tail -n1 || true)"
  line="${line#*=}"
  printf '%s' "$line"
}

write_env_value() {
  local key="$1"
  local value="$2"
  if grep -q -E "^${key}=" "$ENV_FILE"; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
  else
    echo "${key}=${value}" >> "$ENV_FILE"
  fi
}

pause() {
  echo ""
  read -r -p "按回车继续..." _ < /dev/tty || true
}

ask() {
  local prompt="$1"
  local default="$2"
  local var_name="$3"
  local input=""
  if [[ -n "$default" ]]; then
    read -r -p "$prompt [$default]: " input < /dev/tty || true
    eval "$var_name=\"${input:-$default}\""
  else
    read -r -p "$prompt: " input < /dev/tty || true
    eval "$var_name=\"${input:-}\""
  fi
}

ask_secret() {
  local prompt="$1"
  local var_name="$2"
  local input=""
  read -r -s -p "$prompt: " input < /dev/tty || true
  echo "" > /dev/tty
  eval "$var_name=\"${input:-}\""
}

confirm() {
  local prompt="$1"
  local default="${2:-y}"
  local yn=""
  if [[ "$default" == "y" ]]; then
    read -r -p "$prompt [Y/n]: " yn < /dev/tty || true
    yn="${yn:-y}"
  else
    read -r -p "$prompt [y/N]: " yn < /dev/tty || true
    yn="${yn:-n}"
  fi
  [[ "$yn" =~ ^[Yy]$ ]]
}

service_status() { systemctl is-active "$SERVICE_NAME" 2>/dev/null || true; }
timer_status() { systemctl is-active "$TIMER_NAME" 2>/dev/null || true; }

current_timer_time() {
  systemctl cat "$TIMER_NAME" 2>/dev/null | awk -F'=' '/OnCalendar=/{print $2}' | tail -n1 | sed 's/.* //; s/:00$//' || true
}

last_run_time() {
  systemctl show "$SERVICE_NAME" -p ExecMainStartTimestamp --value 2>/dev/null || true
}

last_run_result() {
  systemctl show "$SERVICE_NAME" -p Result --value 2>/dev/null || true
}

current_commit() {
  if [[ -d "$INSTALL_DIR/.git" ]]; then
    git -C "$INSTALL_DIR" rev-parse --short HEAD 2>/dev/null || true
  fi
}

last_upgrade_time() {
  if [[ -f "$INSTALL_DIR/.last_upgrade" ]]; then
    cat "$INSTALL_DIR/.last_upgrade" 2>/dev/null || true
  fi
}

recent_outputs() {
  if [[ ! -d "$OUTPUT_DIR" ]]; then
    return 0
  fi
  find "$OUTPUT_DIR" -maxdepth 1 -type f -printf '%TY-%Tm-%Td %TH:%TM %f\n' 2>/dev/null | sort -r | head -n 5 || true
}

latest_stats_file() {
  if [[ ! -d "$OUTPUT_DIR" ]]; then
    return 0
  fi
  find "$OUTPUT_DIR" -maxdepth 1 -type f -name '*_stats.json' | sort | tail -n 1 || true
}

show_latest_stats_summary() {
  local stats_file
  stats_file="$(latest_stats_file)"
  if [[ -z "$stats_file" || ! -f "$stats_file" ]]; then
    echo "  暂无 stats.json 统计文件"
    return 0
  fi
  python3 - <<'PY' "$stats_file"
import json, sys
p = sys.argv[1]
try:
    data = json.load(open(p, 'r', encoding='utf-8'))
except Exception:
    print('  无法解析最近 stats.json')
    raise SystemExit(0)
keys = ['fetched','kept','analysis_success','analysis_failed','already_reported','below_min_relevance']
print(f'  最近统计文件: {p.split("/")[-1]}')
for k in keys:
    if k in data:
        print(f'  {k}: {data[k]}')
PY
}

backup_dir_root() {
  echo "$INSTALL_DIR/backups"
}

create_backup() {
  local bdir ts
  ts="$(date '+%Y%m%d-%H%M%S')"
  bdir="$(backup_dir_root)/$ts"
  mkdir -p "$bdir"
  cp -f "$ENV_FILE" "$bdir/.env" 2>/dev/null || true
  cp -f "$CONFIG_FILE" "$bdir/config.yaml" 2>/dev/null || true
  cp -f "$INSTALL_DIR/papers.db" "$bdir/papers.db" 2>/dev/null || true
  echo "$bdir"
}

list_backups() {
  local root
  root="$(backup_dir_root)"
  if [[ ! -d "$root" ]]; then
    return 0
  fi
  find "$root" -mindepth 1 -maxdepth 1 -type d | sort -r || true
}

restore_backup() {
  local backup_path="$1"
  [[ -d "$backup_path" ]] || error "备份不存在：$backup_path"
  cp -f "$backup_path/.env" "$ENV_FILE" 2>/dev/null || true
  cp -f "$backup_path/config.yaml" "$CONFIG_FILE" 2>/dev/null || true
  cp -f "$backup_path/papers.db" "$INSTALL_DIR/papers.db" 2>/dev/null || true
  chown -R "$SERVICE_USER":"$SERVICE_USER" "$INSTALL_DIR"
  chmod 600 "$ENV_FILE" 2>/dev/null || true
  info "已恢复备份：$backup_path"
}

read_sources() {
  awk '
    /^sources:/ {in_sources=1; next}
    in_sources && /^[[:space:]]*-[[:space:]]/ {
      sub(/^[[:space:]]*-[[:space:]]*/, "")
      gsub(/[[:space:]]+$/, "")
      print
      next
    }
    in_sources && !/^[[:space:]]*-[[:space:]]/ && NF>0 {exit}
  ' "$CONFIG_FILE" 2>/dev/null
}

write_sources() {
  local new_sources_block="$1"
  python3 - <<'PY' "$CONFIG_FILE" "$new_sources_block"
from pathlib import Path
import sys
cfg_path = Path(sys.argv[1])
block = sys.argv[2].split('\\n') if sys.argv[2] else []
text = cfg_path.read_text(encoding='utf-8')
lines = text.splitlines()
out = []
i = 0
while i < len(lines):
    line = lines[i]
    if line.startswith('sources:'):
        out.append('sources:')
        for item in block:
            if item.strip():
                out.append(f'  - {item.strip()}')
        i += 1
        while i < len(lines):
            if lines[i].startswith('  - ') or lines[i].startswith('    #') or lines[i].strip() == '':
                i += 1
                continue
            break
        continue
    out.append(line)
    i += 1
cfg_path.write_text('\\n'.join(out) + '\\n', encoding='utf-8')
PY
}

list_target_journals() {
  python3 - <<'PY' "$CONFIG_FILE"
from pathlib import Path
import sys, re
text = Path(sys.argv[1]).read_text(encoding='utf-8')
lines = text.splitlines()
in_block = False
current_name = None
for line in lines:
    if line.startswith('target_journals:'):
        in_block = True
        continue
    if in_block and line.startswith('db_path:'):
        break
    if not in_block:
        continue
    m1 = re.match(r'^\s*-\s+name:\s+"?(.*?)"?\s*$', line)
    if m1:
        current_name = m1.group(1)
        continue
    m2 = re.match(r'^\s+issn:\s+"?(.*?)"?\s*$', line)
    if m2 and current_name:
        print(f'{current_name}\t{m2.group(1)}')
        current_name = None
PY
}

add_target_journal() {
  local jname="$1"
  local jissn="$2"
  python3 - <<'PY' "$CONFIG_FILE" "$jname" "$jissn"
from pathlib import Path
import sys
cfg = Path(sys.argv[1])
name = sys.argv[2]
issn = sys.argv[3]
text = cfg.read_text(encoding='utf-8')
needle = 'db_path:'
insert = f'  - name: "{name}"\n    issn: "{issn}"\n\n'
idx = text.find(needle)
if idx == -1:
    raise SystemExit('db_path section not found')
text = text[:idx] + insert + text[idx:]
cfg.write_text(text, encoding='utf-8')
PY
}

delete_target_journal_by_index() {
  local index="$1"
  python3 - <<'PY' "$CONFIG_FILE" "$index"
from pathlib import Path
import sys, re
cfg = Path(sys.argv[1])
remove_index = int(sys.argv[2])
lines = cfg.read_text(encoding='utf-8').splitlines()
out = []
in_block = False
capture = []
entries = []
for line in lines:
    if line.startswith('target_journals:'):
        in_block = True
        out.append(line)
        continue
    if in_block and line.startswith('db_path:'):
        in_block = False
        if entries:
            for idx, ent in enumerate(entries, start=1):
                if idx != remove_index:
                    out.extend(ent)
        out.append(line)
        continue
    if in_block:
        if re.match(r'^\s*-\s+name:', line):
            if capture:
                entries.append(capture)
            capture = [line]
        elif capture:
            capture.append(line)
        else:
            out.append(line)
    else:
        out.append(line)
if capture:
    entries.append(capture)
if in_block:
    for idx, ent in enumerate(entries, start=1):
        if idx != remove_index:
            out.extend(ent)
cfg.write_text('\n'.join(out) + '\n', encoding='utf-8')
PY
}

show_header() {
  clear || true
  echo -e "${BOLD}==========================================${NC}"
  echo -e "${BOLD} essay-agent 终端控制台 (esag)${NC}"
  echo -e "${BOLD}==========================================${NC}"
  if is_installed; then
    echo "安装状态: 已安装"
    echo "安装目录: $INSTALL_DIR"
  else
    echo "安装状态: 未安装"
    echo "安装目录: $INSTALL_DIR"
  fi
  echo ""
}

show_dashboard() {
  ensure_installed || return 1
  local s t last_start last_result run_time source_count journal_count outputs commit_id upgraded_at
  s="$(service_status)"
  t="$(timer_status)"
  last_start="$(last_run_time)"
  last_result="$(last_run_result)"
  run_time="$(current_timer_time)"
  run_time="${run_time:-07:00}"
  commit_id="$(current_commit)"
  upgraded_at="$(last_upgrade_time)"
  source_count="$(awk '
    /^sources:/ {in_sources=1; next}
    in_sources && /^[[:space:]]*-[[:space:]]/ {count++}
    in_sources && !/^[[:space:]]*-[[:space:]]/ && NF>0 {in_sources=0}
    END {print count+0}
  ' "$CONFIG_FILE" 2>/dev/null)"
  journal_count="$(awk '
    /^target_journals:/ {in_j=1; next}
    in_j && /^[[:space:]]*-[[:space:]]+name:/ {count++}
    END {print count+0}
  ' "$CONFIG_FILE" 2>/dev/null)"

  echo "[状态面板]"
  echo "  服务状态        : ${s:-unknown}"
  echo "  定时器状态      : ${t:-unknown}"
  echo "  每日运行时间    : $run_time"
  echo "  当前版本(commit): ${commit_id:-unknown}"
  echo "  最近升级时间    : ${upgraded_at:-unknown}"
  echo "  上次运行时间    : ${last_start:-unknown}"
  echo "  上次运行结果    : ${last_result:-unknown}"
  echo ""
  echo "[配置摘要]"
  echo "  模型            : $(read_env_value OPENAI_MODEL)"
  echo "  抓取天数        : $(read_env_value DAYS_BACK)"
  echo "  每路抓取上限    : $(read_env_value MAX_RESULTS_PER_QUERY)"
  echo "  相关性阈值      : $(read_env_value MIN_RELEVANCE_SCORE)"
  echo "  Markdown 展示数 : $(read_env_value REPORT_TOP_N)"
  echo "  邮件正文展示数  : $(read_env_value EMAIL_TOP_N)"
  echo "  待展示池天数    : $(read_env_value PENDING_POOL_DAYS)"
  if [[ "$(read_env_value EMAIL_ENABLED)" == "true" ]]; then
    echo "  邮件推送        : 开启"
    echo "  收件人          : $(read_env_value EMAIL_TO)"
  else
    echo "  邮件推送        : 关闭"
  fi
  if [[ -n "$(read_env_value CORE_API_KEY)" ]]; then
    echo "  CORE API        : 已配置"
  else
    echo "  CORE API        : 未配置"
  fi
  echo ""
  echo "[数据源与期刊]"
  echo "  启用数据源数量  : ${source_count:-0}"
  echo "  目标期刊数量    : ${journal_count:-0}"
  local source_list
  source_list="$(read_sources | paste -sd ', ' -)"
  if [[ -n "$source_list" ]]; then
    echo "  启用数据源名单  : $source_list"
  else
    echo "  启用数据源名单  : （未检测到）"
  fi
  echo ""
  echo "[最近运行统计摘要]"
  show_latest_stats_summary
  echo ""
  echo "[最近输出文件]"
  outputs="$(recent_outputs)"
  if [[ -n "$outputs" ]]; then
    echo "$outputs" | sed 's/^/  /'
  else
    echo "  暂无输出文件（可能尚未运行，或 output 目录为空）"
  fi
  echo ""
}

run_installer() {
  require_root
  step "安装 / 重装 essay-agent"
  if [[ -f "$DEPLOY_SCRIPT" ]]; then
    bash "$DEPLOY_SCRIPT"
    return
  fi
  local tmp_script
  tmp_script="$(mktemp /tmp/essay-agent-deploy.XXXXXX.sh)"
  trap 'rm -f "$tmp_script"' RETURN
  info "未检测到本地部署脚本，正在临时下载 deploy.sh ..."
  if ! curl -fsSL "https://raw.githubusercontent.com/wannaqueen66-create/essay-agent/main/deploy.sh" -o "$tmp_script"; then
    error "无法下载 deploy.sh，请检查当前服务器是否能访问 raw.githubusercontent.com"
  fi
  chmod +x "$tmp_script"
  bash "$tmp_script"
}

run_now() { ensure_installed || return 1; step "立即执行一次主程序"; sudo -u "$SERVICE_USER" bash -lc "cd '$INSTALL_DIR' && '$VENV_PY' essay_agent.py"; }
view_logs() { ensure_installed || return 1; step "查看最近日志"; journalctl -u "$SERVICE_NAME" -n 200 --no-pager; }
follow_logs() { ensure_installed || return 1; step "实时跟踪日志"; journalctl -u "$SERVICE_NAME" -f; }
inspect_db() { ensure_installed || return 1; step "数据库总览"; sudo -u "$SERVICE_USER" bash -lc "cd '$INSTALL_DIR' && '$VENV_PY' inspect_db.py"; }
show_pending() { ensure_installed || return 1; step "待展示池"; sudo -u "$SERVICE_USER" bash -lc "cd '$INSTALL_DIR' && '$VENV_PY' show_pending_pool.py"; }
test_email() { ensure_installed || return 1; step "测试邮箱"; sudo -u "$SERVICE_USER" bash -lc "cd '$INSTALL_DIR' && '$VENV_PY' test_email.py"; }
open_env_editor() { ensure_installed || return 1; ${EDITOR:-nano} "$ENV_FILE"; }
open_config_editor() { ensure_installed || return 1; ${EDITOR:-nano} "$CONFIG_FILE"; }

apply_timer_time() {
  local run_time="$1"
  sed -i "s|OnCalendar=.*|OnCalendar=*-*-* ${run_time}:00|" /etc/systemd/system/essay-agent.timer
  systemctl daemon-reload
  systemctl restart "$TIMER_NAME"
}

edit_core_settings() {
  ensure_installed || return 1
  step "核心配置"
  local current_model current_days current_max current_score current_report current_email_top current_pending current_time
  current_model="$(read_env_value OPENAI_MODEL)"
  current_days="$(read_env_value DAYS_BACK)"
  current_max="$(read_env_value MAX_RESULTS_PER_QUERY)"
  current_score="$(read_env_value MIN_RELEVANCE_SCORE)"
  current_report="$(read_env_value REPORT_TOP_N)"
  current_email_top="$(read_env_value EMAIL_TOP_N)"
  current_pending="$(read_env_value PENDING_POOL_DAYS)"
  current_time="$(current_timer_time)"; current_time="${current_time:-07:00}"
  ask "模型名称" "$current_model" new_model
  ask "抓取最近几天论文（DAYS_BACK）" "$current_days" new_days
  ask "每个 query 每个源最大抓取数（MAX_RESULTS_PER_QUERY）" "$current_max" new_max
  ask "最低相关性阈值（MIN_RELEVANCE_SCORE）" "$current_score" new_score
  ask "Markdown 报告展示前 N 条（REPORT_TOP_N）" "$current_report" new_report
  ask "邮件正文展示前 N 条（EMAIL_TOP_N）" "$current_email_top" new_email_top
  ask "待展示池窗口天数（PENDING_POOL_DAYS）" "$current_pending" new_pending
  ask "每天自动运行时间（如 07:00）" "$current_time" new_time
  write_env_value OPENAI_MODEL "$new_model"
  write_env_value DAYS_BACK "$new_days"
  write_env_value MAX_RESULTS_PER_QUERY "$new_max"
  write_env_value MIN_RELEVANCE_SCORE "$new_score"
  write_env_value REPORT_TOP_N "$new_report"
  write_env_value EMAIL_TOP_N "$new_email_top"
  write_env_value PENDING_POOL_DAYS "$new_pending"
  apply_timer_time "$new_time"
  info "核心配置已更新"
}

edit_email_settings() {
  ensure_installed || return 1
  step "邮件配置"
  local enabled host port username password from to tls
  enabled="$(read_env_value EMAIL_ENABLED)"
  host="$(read_env_value EMAIL_SMTP_HOST)"
  port="$(read_env_value EMAIL_SMTP_PORT)"
  username="$(read_env_value EMAIL_USERNAME)"
  from="$(read_env_value EMAIL_FROM)"
  to="$(read_env_value EMAIL_TO)"
  tls="$(read_env_value EMAIL_USE_TLS)"
  if [[ "$enabled" == "true" ]]; then
    if confirm "是否继续启用邮件推送？" "y"; then enabled="true"; else enabled="false"; fi
  else
    if confirm "是否启用邮件推送？" "n"; then enabled="true"; else enabled="false"; fi
  fi
  if [[ "$enabled" == "true" ]]; then
    ask "SMTP 主机" "${host:-smtp-relay.brevo.com}" host
    ask "SMTP 端口" "${port:-587}" port
    ask "SMTP 用户名" "$username" username
    ask_secret "SMTP 密码（留空则保留原值）" password
    ask "发件人邮箱" "$from" from
    ask "收件人邮箱（多个用英文逗号分隔）" "$to" to
    ask "是否启用 TLS（true/false）" "${tls:-true}" tls
    write_env_value EMAIL_ENABLED "$enabled"
    write_env_value EMAIL_SMTP_HOST "$host"
    write_env_value EMAIL_SMTP_PORT "$port"
    write_env_value EMAIL_USERNAME "$username"
    if [[ -n "$password" ]]; then write_env_value EMAIL_PASSWORD "$password"; fi
    write_env_value EMAIL_FROM "$from"
    write_env_value EMAIL_TO "$to"
    write_env_value EMAIL_USE_TLS "$tls"
  else
    write_env_value EMAIL_ENABLED false
  fi
  info "邮件配置已更新"
}

edit_source_settings() {
  ensure_installed || return 1
  step "数据源与 CORE 配置"
  local current_core available_sources current_sources selected_sources source existing
  current_core="$(read_env_value CORE_API_KEY)"
  available_sources=(arxiv openalex crossref semantic_scholar europepmc core)
  mapfile -t current_sources < <(read_sources)
  selected_sources=()
  echo "当前启用的数据源："
  if [[ ${#current_sources[@]} -gt 0 ]]; then for source in "${current_sources[@]}"; do echo "  - $source"; done; else echo "  （未检测到）"; fi
  echo ""
  echo "你可以逐个决定是否启用下面的数据源："
  for source in "${available_sources[@]}"; do
    local default_choice="n"
    for existing in "${current_sources[@]:-}"; do
      if [[ "$existing" == "$source" ]]; then default_choice="y"; break; fi
    done
    if confirm "启用数据源 $source ?" "$default_choice"; then selected_sources+=("$source"); fi
  done
  if [[ ${#selected_sources[@]} -gt 0 ]]; then
    write_sources "$(printf '%s\n' "${selected_sources[@]}")"
    info "数据源列表已更新"
  else
    warn "你没有启用任何数据源，已保留原配置不变"
  fi
  echo ""
  if [[ -n "$current_core" ]]; then echo "当前 CORE API Key：已配置"; else echo "当前 CORE API Key：未配置"; fi
  if confirm "是否配置 / 更新 CORE API Key？" "n"; then
    ask_secret "CORE API Key（留空可清空）" new_core
    write_env_value CORE_API_KEY "$new_core"
    info "CORE API Key 已更新"
  fi
}

manage_target_journals() {
  ensure_installed || return 1
  while true; do
    show_header
    echo "[目标期刊管理]"
    local idx=1
    while IFS=$'\t' read -r name issn; do
      [[ -n "$name" ]] || continue
      echo "[$idx] $name ($issn)"
      idx=$((idx+1))
    done < <(list_target_journals)
    echo ""
    cat <<'EOF'
[a] 新增期刊
[d] 删除期刊
[e] 打开 config.yaml 手动编辑
[q] 返回主菜单
EOF
    echo ""
    read -r -p "请选择操作: " choice < /dev/tty || true
    case "$choice" in
      a|A)
        ask "期刊名称" "" jname
        ask "ISSN" "" jissn
        if [[ -n "$jname" && -n "$jissn" ]]; then add_target_journal "$jname" "$jissn"; info "已新增期刊：$jname ($jissn)"; else warn "名称或 ISSN 为空，已取消"; fi
        pause ;;
      d|D)
        ask "输入要删除的期刊编号" "" del_idx
        if [[ -n "$del_idx" ]]; then delete_target_journal_by_index "$del_idx"; info "已尝试删除编号 $del_idx 的期刊"; fi
        pause ;;
      e|E) open_config_editor; pause ;;
      q|Q) return ;;
      *) warn "无效选择"; pause ;;
    esac
  done
}

backup_restore_menu() {
  ensure_installed || return 1
  while true; do
    show_header
    echo "[备份 / 恢复]"
    echo "当前备份目录：$(backup_dir_root)"
    echo ""
    cat <<'EOF'
[1] 创建新备份
[2] 查看现有备份
[3] 恢复指定备份
[4] 返回主菜单
EOF
    echo ""
    read -r -p "请选择操作: " choice < /dev/tty || true
    case "$choice" in
      1) created="$(create_backup)"; info "已创建备份：$created"; pause ;;
      2) list_backups | sed 's/^/  /' || true; pause ;;
      3)
        echo "可用备份："
        list_backups | sed 's/^/  /' || true
        ask "输入完整备份目录路径" "" restore_path
        if [[ -n "$restore_path" ]]; then restore_backup "$restore_path"; fi
        pause ;;
      4) return ;;
      *) warn "无效选择"; pause ;;
    esac
  done
}

refresh_esag_only() {
  require_root
  step "更新 esag 控制台脚本"
  local tmp_esag
  tmp_esag="$(mktemp /tmp/esag-refresh.XXXXXX.sh)"
  trap 'rm -f "$tmp_esag"' RETURN
  if ! curl -fsSL "https://raw.githubusercontent.com/wannaqueen66-create/essay-agent/main/esag" -o "$tmp_esag"; then
    error "无法下载最新 esag，请检查当前服务器是否能访问 raw.githubusercontent.com"
  fi
  chmod 755 "$tmp_esag"
  cp "$tmp_esag" /usr/local/bin/esag
  info "esag 已更新到最新版本"
  warn "如果 shell 里还缓存旧路径，请执行：hash -r"
}

upgrade_program_keep_config() {
  ensure_installed || return 1
  step "升级程序（保留当前配置）"
  local tmp_src backup_dir before_commit after_commit
  tmp_src="$(mktemp -d /tmp/essay-agent-upgrade.XXXXXX)"
  backup_dir="$(mktemp -d /tmp/essay-agent-backup.XXXXXX)"
  trap 'rm -rf "$tmp_src" "$backup_dir"' RETURN
  before_commit="$(current_commit)"
  info "当前版本: ${before_commit:-unknown}"
  info "备份当前关键文件 ..."
  cp -f "$ENV_FILE" "$backup_dir/.env"
  cp -f "$CONFIG_FILE" "$backup_dir/config.yaml"
  if [[ -f "$INSTALL_DIR/papers.db" ]]; then cp -f "$INSTALL_DIR/papers.db" "$backup_dir/papers.db"; fi
  info "拉取最新代码 ..."
  if ! git clone --depth=1 --branch main "https://github.com/wannaqueen66-create/essay-agent.git" "$tmp_src" >/dev/null 2>&1; then
    error "升级失败：无法拉取最新仓库代码"
  fi
  info "同步程序文件 ..."
  if ! cp -a "$tmp_src"/. "$INSTALL_DIR"/; then
    warn "程序文件同步失败，开始回滚配置备份 ..."
    cp -f "$backup_dir/.env" "$ENV_FILE" 2>/dev/null || true
    cp -f "$backup_dir/config.yaml" "$CONFIG_FILE" 2>/dev/null || true
    [[ -f "$backup_dir/papers.db" ]] && cp -f "$backup_dir/papers.db" "$INSTALL_DIR/papers.db" 2>/dev/null || true
    error "升级失败：文件同步异常，已尝试回滚配置备份"
  fi
  info "恢复原配置 ..."
  cp -f "$backup_dir/.env" "$ENV_FILE"
  cp -f "$backup_dir/config.yaml" "$CONFIG_FILE"
  [[ -f "$backup_dir/papers.db" ]] && cp -f "$backup_dir/papers.db" "$INSTALL_DIR/papers.db"
  info "刷新依赖与服务文件 ..."
  "$INSTALL_DIR/.venv/bin/pip" install -q --upgrade pip >/dev/null 2>&1 || true
  if ! "$INSTALL_DIR/.venv/bin/pip" install -q -r "$INSTALL_DIR/requirements.txt" >/dev/null 2>&1; then
    warn "依赖安装失败，开始回滚配置备份 ..."
    cp -f "$backup_dir/.env" "$ENV_FILE" 2>/dev/null || true
    cp -f "$backup_dir/config.yaml" "$CONFIG_FILE" 2>/dev/null || true
    [[ -f "$backup_dir/papers.db" ]] && cp -f "$backup_dir/papers.db" "$INSTALL_DIR/papers.db" 2>/dev/null || true
    error "升级失败：依赖安装异常，已回滚配置备份"
  fi
  cp "$INSTALL_DIR/deploy/essay-agent.service" /etc/systemd/system/
  cp "$INSTALL_DIR/deploy/essay-agent.timer" /etc/systemd/system/
  cp "$INSTALL_DIR/esag" /usr/local/bin/esag
  chmod 755 /usr/local/bin/esag
  chown -R "$SERVICE_USER":"$SERVICE_USER" "$INSTALL_DIR"
  chmod 600 "$ENV_FILE"
  systemctl daemon-reload
  systemctl restart "$TIMER_NAME" >/dev/null 2>&1 || true
  after_commit="$(current_commit)"
  date '+%Y-%m-%d %H:%M:%S %Z' > "$INSTALL_DIR/.last_upgrade"
  info "升级完成：${before_commit:-unknown} -> ${after_commit:-unknown}"
  info "已保留现有 .env / config.yaml / papers.db"
}

rerun_deploy() { ensure_installed || return 1; step "全量重配（重新执行部署脚本）"; bash "$DEPLOY_SCRIPT"; }

uninstall_agent() {
  ensure_installed || return 1
  echo ""
  echo -e "${YELLOW}你将要卸载 essay-agent：${NC}"
  echo "- 停止并移除 systemd service/timer"
  echo "- 删除 /usr/local/bin/esag 和 /usr/bin/esag（如果存在）"
  echo "- 删除 $INSTALL_DIR"
  echo "- 删除服务用户 $SERVICE_USER（如果存在）"
  echo ""
  read -r -p "确认卸载？请输入 yes 继续: " ans < /dev/tty || true
  if [[ "$ans" != "yes" ]]; then warn "已取消卸载"; return; fi
  systemctl disable --now "$TIMER_NAME" >/dev/null 2>&1 || true
  systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
  rm -f "/etc/systemd/system/essay-agent.service" "/etc/systemd/system/essay-agent.timer"
  systemctl daemon-reload || true
  rm -f /usr/local/bin/esag /usr/bin/esag
  rm -rf "$INSTALL_DIR"
  if id "$SERVICE_USER" >/dev/null 2>&1; then userdel "$SERVICE_USER" >/dev/null 2>&1 || true; fi
  info "essay-agent 已卸载"
  warn "如果当前 shell 仍记住旧 esag 路径，请执行：hash -r"
  exit 0
}

